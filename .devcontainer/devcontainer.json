{
  "name": "Proxmox Homelab IaC",
  
  "image": "mcr.microsoft.com/devcontainers/base:debian",

  "features": {
    "ghcr.io/devcontainers/features/nix:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true
    }
  },

  "runArgs": [
    "--env-file", ".env"
  ],

  "mounts": [
    {
      "source": "${localEnv:TF_VAR_sops_ssh_key_path}",
      "target": "${localEnv:TF_VAR_sops_ssh_key_path}",
      "type": "bind"
    }
  ],

  "containerEnv": {
    "SOPS_SSH_KEY_PATHS": "${localEnv:TF_VAR_sops_ssh_key_path}",
    "SOPS_IMPORT_PGP": "false"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "opentofu.opentofu",        // OpenTofu Support
        "jnoortheen.nix-ide",      // Nix Support
        "mkhl.direnv",             // Auto-load .env
        "signageos.signageos-vscode-sops", // SOPS Editor Support
        "ms-azuretools.vscode-docker"      // Docker Management
      ],
      "settings": {
        "nix.enableLanguageServer": true,
        "nix.serverPath": "nil",
        "opentofu.lint.enable": true
      }
    }
  },

  "postCreateCommand": "sudo chmod 600 ${containerEnv:SOPS_SSH_KEY_PATHS} && nix-channel --update",

  "remoteUser": "vscode"
}