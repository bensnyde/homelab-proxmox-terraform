{
  "name": "Homelab IaC",
  "build": { "dockerfile": "Dockerfile" },
  
  // 1. Load all TF_VARs from your .env into the container shell
  "runArgs": ["--env-file", ".env"],

  "mounts": [
    // 2. Map the host's SSH key to the container's internal path.
    // We use ${localEnv} to pull the path directly from your Fedora environment.
    "source=${localEnv:TF_VAR_sops_ssh_key_path},target=${localEnv:TF_VAR_sops_ssh_key_path},type=bind,readonly"
  ],

  "containerEnv": {
    // 3. Tell SOPS to use the SSH key for decryption
    "SOPS_IMPORT_PGP": "false",
    "SOPS_AGE_KEY_FILE": "" // Disable Age if you are strictly using SSH keys
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "opentofu.opentofu",
        "jnoortheen.nix-ide",
        "signageos.signageos-vscode-sops"
      ]
    }
  },
  "remoteUser": "vscode"
}