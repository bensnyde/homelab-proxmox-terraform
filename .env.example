# Sourced via: source .env

# --- Provisioning Toggles (true/false) ---
export TF_VAR_deploy_haos="true"
export TF_VAR_deploy_adguard="true"
export TF_VAR_deploy_portainer="true"

# --- Proxmox Connection Details ---
export TF_VAR_proxmox_endpoint="https://192.168.1.100:8006/"
export TF_VAR_proxmox_username="root@pam"
export TF_VAR_proxmox_password="your-proxmox-password"

# --- Cloudflare R2 Settings ---
export TF_VAR_r2_account_id="your-r2-id"
export TF_VAR_r2_bucket="your-r2-bucket-name"

# --- Amazon S3 Settings ---
export TF_VAR_s3_bucket="your-s3-bucket-name"
export TF_VAR_s3_region="us-east-1"

# --- Shared Credentials (Used by both) ---
export AWS_ACCESS_KEY_ID="your-access-key"
export AWS_SECRET_ACCESS_KEY="your-secret-key"

# --- Repo Details ---
export TF_VAR_github_repo="https://github.com/bensnyde/homelab-proxmox-terraform"

# --- Security & SSH Paths ---
export TF_VAR_ssh_public_key='["ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIL/vxzM4LJo1KP01UEgouFiHbChDH1OYPg9Mykvj03lN user@host"]'
export TF_VAR_sops_ssh_key_path="~/.ssh/id_ed25519"
export TF_VAR_provisioner_private_key="~/.ssh/id_ed25519"

# --- Dynamic URLs & Inputs ---
export TF_VAR_nixos_repo="github:NixOS/nixpkgs/nixos-24.11"
export TF_VAR_sops_nix_url="github:Mic92/sops-nix"
export TF_VAR_haos_image_url="https://github.com/home-assistant/operating-system/releases/download/17.1/haos_ova-17.1.qcow2.xz"

# --- VM IDs ---
export TF_VAR_haos_vm_id=101
export TF_VAR_adguard_vm_id=102
export TF_VAR_portainer_vm_id=103

# --- Identity, Localization & Network ---
export TF_VAR_timezone="America/New_York"
export TF_VAR_auto_update_schedule="02:00"

export TF_VAR_haos_hostname="HomeAssistant"
export TF_VAR_haos_ip="192.168.1.49"
export TF_VAR_ha_name="My Home"
export TF_VAR_ha_unit_system="metric"
export TF_VAR_ha_currency="USD"

export TF_VAR_adguard_hostname="nixos-adguard"
export TF_VAR_adguard_ip="192.168.1.50"

export TF_VAR_portainer_hostname="nixos-portainer"
export TF_VAR_portainer_ip="192.168.1.51"
export TF_VAR_portainer_port_http=8000
export TF_VAR_portainer_port_https=9443

# --- VM Hardware Allocation ---
export TF_VAR_haos_cores=2
export TF_VAR_haos_memory=4096
export TF_VAR_haos_disk_size=32
export TF_VAR_adguard_cores=2
export TF_VAR_adguard_memory=2048
export TF_VAR_adguard_disk_size=32
export TF_VAR_portainer_cores=2
export TF_VAR_portainer_memory=2048
export TF_VAR_portainer_disk_size=32